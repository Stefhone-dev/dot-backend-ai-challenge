# ============================================================
# Configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves
# cp .env.example .env
# ============================================================

# --- Questão 2: Chatbot com LLM ---
# Provedor do LLM: "openai" (padrão) ou "groq" (alternativa gratuita)
LLM_PROVIDER=openai

# OpenAI (padrão exigido pelo desafio)
OPENAI_API_KEY=sua-chave-openai-aqui

# Groq (alternativa gratuita para testes locais)
# Crie sua key em: https://console.groq.com
GROQ_API_KEY=sua-chave-groq-aqui

# Modelo do LLM (opcional, usa padrão se não definido)
# OpenAI: gpt-4 (padrão)
# Groq: llama-3.3-70b-versatile (padrão)
LLM_MODEL=
